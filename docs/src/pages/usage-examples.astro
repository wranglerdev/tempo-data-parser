---
import DocLayout from "../layouts/DocLayout.astro";
import { Code } from 'astro:components';

const errorSnippet = `try {
  const resultado = tempo('data inválida');
} catch (e) {
  console.error("Não foi possível interpretar a data");
}`;
---

<DocLayout title="Exemplos de Uso">
  <h1>Exemplos de Uso</h1>
  
  <p>
    Explore padrões e expressões comuns suportados pelo <strong>Tempo</strong>.
  </p>

  <h2>Datas Únicas</h2>
  <p>Expressões de datas relativas e absolutas em PT-BR.</p>
  
  <div class="overflow-x-auto">
    <table class="table">
      <thead>
        <tr>
          <th>Entrada</th>
          <th>Descrição</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>"hoje"</code></td>
          <td>O dia atual</td>
        </tr>
        <tr>
          <td><code>"amanhã"</code></td>
          <td>O dia seguinte</td>
        </tr>
        <tr>
          <td><code>"ontem"</code></td>
          <td>O dia anterior</td>
        </tr>
        <tr>
          <td><code>"daqui a 3 dias"</code></td>
          <td>Três dias no futuro</td>
        </tr>
        <tr>
          <td><code>"próxima segunda"</code></td>
          <td>A próxima segunda-feira vindo</td>
        </tr>
        <tr>
          <td><code>"15 de janeiro"</code></td>
          <td>15 de janeiro do ano atual</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="mt-16">Intervalos de Datas</h2>
  <p>Intervalos entre duas datas.</p>

  <div class="overflow-x-auto">
    <table class="table">
      <thead>
        <tr>
          <th>Entrada</th>
          <th>Descrição</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>"hoje até amanhã"</code></td>
          <td>Intervalo de hoje até amanhã</td>
        </tr>
        <tr>
          <td><code>"de ontem a hoje"</code></td>
          <td>Intervalo de ontem até hoje</td>
        </tr>
        <tr>
          <td><code>"próxima semana"</code></td>
          <td>Intervalo cobrindo os próximos 7 dias</td>
        </tr>
        <tr>
          <td><code>"mês que vem"</code></td>
          <td>Intervalo cobrindo todo o próximo mês</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="mt-16">Uso Avançado</h2>
  <p>Tratamento de erros e entradas inválidas.</p>
  
  <div class="mockup-code mt-4 max-h-[500px] overflow-auto relative group not-prose">
    <button 
      class="btn btn-xs btn-ghost absolute right-4 top-2 z-10 opacity-0 group-hover:opacity-100 transition-opacity"
      onclick="navigator.clipboard.writeText(this.parentElement.querySelector('code').innerText); alert('Código copiado!')"
    >
      Copiar
    </button>
    <Code code={errorSnippet} lang="ts" theme="nord" class="bg-transparent! px-5" />
  </div>
</DocLayout>